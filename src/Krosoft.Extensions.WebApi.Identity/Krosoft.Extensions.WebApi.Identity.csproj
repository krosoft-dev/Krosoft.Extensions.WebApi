<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<PackageTags>Krosoft Extension Web Api AspNetCore identity</PackageTags>
		<Description>Package pour faciliter l'utilisation d'Identity avec ASP.NET Core.</Description>
	</PropertyGroup>
	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.9" />
		<PackageReference Include="System.Security.Cryptography.Pkcs" Version="10.0.9" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Krosoft.Extensions.Core" Version="2026.6.30.7936" />
		<PackageReference Include="Krosoft.Extensions.Identity" Version="2026.6.25.7891" />
		<PackageReference Include="Krosoft.Extensions.Identity.Abstractions" Version="2026.6.25.7891" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\Krosoft.Extensions.WebApi\Krosoft.Extensions.WebApi.csproj" />
	</ItemGroup>
</Project>